geom_sf(data = coastline, fill = ocean_color, color = NA) +
geom_sf(data = land, fill = land_color) +
geom_sf(data = cafes, aes(shape = chain, color = chain), size = 3) +
scale_color_scico_d(palette = 'lajolla', begin = .1, end = .9,
name = " اسم شركة مقهى") +
scale_shape_manual(values = c(15, 16, 17, 18, 19),
name = " اسم شركة مقهى") +
labs(title = "عنوان في اللغة العربية") +
theme(plot.title = ggplot2::element_text(size = 20))
ggsave('text.png')
