facet_wrap(~life_stage, scales = 'free_y') +
geom_line(data = df_timeseries, aes(x = year, y = avgCount, color = life_stage, group = interaction(replicate, run_id)), alpha = .5) +
scale_fill_manual(values = c("Seedling" = "#F4C27F", "Juvenile" = "#78985A",
"Adult" = "#476877", "Burned" = "#CC0000", "Resprout" = "#FF9999"), name = "")
df_timeseries = dbGetQuery(con,
paste0(
"SELECT year, run_id, replicate,",
" AVG(numAdult) AS numAdult, AVG(treeCount) AS treeCount, AVG(numJuvenile) AS numJuvenile, AVG(numSeedling) AS numSeedling",
" FROM cell_data WHERE run_hash = '", run_hash, "'",
" GROUP BY year, run_id, replicate"
)) %>%
pivot_longer(cols = c(numAdult, numJuvenile, numSeedling), names_to = "life_stage", values_to = "avgCount") %>%
mutate(life_stage = case_when(
life_stage == "numSeedling" ~ "Seedling",
life_stage == "numJuvenile" ~ "Juvenile",
life_stage == "numAdult" ~ "Adult"
))
ggplot() + theme_bw() +
facet_wrap(~life_stage, scales = 'free_y') +
geom_line(data = df_timeseries, aes(x = year, y = avgCount, color = life_stage, group = interaction(replicate, run_id)), alpha = .5) +
scale_fill_manual(values = c("Seedling" = "#F4C27F", "Juvenile" = "#78985A",
"Adult" = "#476877", "Burned" = "#CC0000", "Resprout" = "#FF9999"), name = "")
ggplot() + theme_bw() +
facet_wrap(~life_stage, scales = 'free_y') +
geom_line(data = df_timeseries, aes(x = year, y = avgCount, color = life_stage, group = interaction(replicate, run_id)), alpha = .5) +
scale_color_manual(values = c("Seedling" = "#F4C27F", "Juvenile" = "#78985A",
"Adult" = "#476877", "Burned" = "#CC0000", "Resprout" = "#FF9999"), name = "")
ggplot() + theme_bw() +
facet_wrap(~life_stage, scales = 'free_y', ncol = 1) +
geom_line(data = df_timeseries, aes(x = year, y = avgCount, color = life_stage, group = interaction(replicate, run_id)), alpha = .5) +
scale_color_manual(values = c("Seedling" = "#F4C27F", "Juvenile" = "#78985A",
"Adult" = "#476877", "Burned" = "#CC0000", "Resprout" = "#FF9999"), name = "")
